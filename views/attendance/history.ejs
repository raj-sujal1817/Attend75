<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head', { title: 'Attendance History' }) %></head>
<body>

<%- include('../partials/navbar', { page: 'attendance', user: typeof user !== 'undefined' ? user : { username: 'Rahul' } }) %>

<main class="container-fluid px-4 py-4" style="max-width:1200px;">

  <div class="d-flex flex-wrap align-items-center justify-content-between mb-4 gap-3">
    <div>
      <h2 class="fw-bold mb-0" style="font-family:'Poppins',sans-serif;color:#1a3a5c;">Attendance History</h2>
      <p class="text-muted mb-0 small">View your complete attendance record</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <select class="form-select" style="max-width:200px;" onchange="filterBySubject(this)">
        <option value="">All Subjects</option>
        <option value="Mathematics">Mathematics</option>
        <option value="Physics">Physics</option>
        <option value="Chemistry">Chemistry</option>
        <option value="Data Structures">Data Structures</option>
      </select>
    </div>
  </div>

  <!-- Desktop View: Table -->
  <div class="card d-none d-lg-block">
    <%
      const history = typeof attendanceHistory !== 'undefined' ? attendanceHistory : [
        { date: new Date('2025-06-10'), subject: 'Mathematics',      status: 'present' },
        { date: new Date('2025-06-10'), subject: 'Physics',          status: 'present' },
        { date: new Date('2025-06-09'), subject: 'Mathematics',      status: 'absent'  },
        { date: new Date('2025-06-09'), subject: 'Chemistry',        status: 'present' },
        { date: new Date('2025-06-08'), subject: 'Data Structures',  status: 'present' },
        { date: new Date('2025-06-08'), subject: 'Physics',          status: 'present' },
        { date: new Date('2025-06-07'), subject: 'Mathematics',      status: 'present' },
        { date: new Date('2025-06-06'), subject: 'Chemistry',        status: 'absent'  },
        { date: new Date('2025-06-05'), subject: 'Data Structures',  status: 'present' },
        { date: new Date('2025-06-05'), subject: 'Physics',          status: 'present' },
      ];
    %>
    <% if (history && history.length > 0) { %>
      <table class="table mb-0">
        <thead>
          <tr>
            <th style="width:30%;"><i class="bi bi-calendar me-1"></i>Date</th>
            <th style="width:30%;"><i class="bi bi-journal-text me-1"></i>Subject</th>
            <th style="width:20%;"><i class="bi bi-check-circle me-1"></i>Status</th>
            <th style="width:20%;"><i class="bi bi-clock me-1"></i>Recorded At</th>
          </tr>
        </thead>
        <tbody>
          <% history.forEach(function(record) { %>
            <%
              const isPresent = record.status === 'present';
              const badgeBg = isPresent ? '#d1fae5' : '#fee2e2';
              const badgeTxt = isPresent ? '#065f46' : '#991b1b';
            %>
            <tr>
              <td>
                <span class="fw-semibold"><%= record.date.toLocaleDateString('en-IN', { weekday:'short', year:'numeric', month:'short', day:'numeric' }) %></span>
              </td>
              <td><%= record.subjectName %></td>
              <td>
                <span class="badge rounded-pill fw-semibold" style="background:<%= badgeBg %>;color:<%= badgeTxt %>;">
                  <i class="bi me-1" style="font-size:0.85rem;" class="<%= isPresent ? 'bi-check-circle' : 'bi-x-circle' %>"></i>
                  <%= isPresent ? 'Present' : 'Absent' %>
                </span>
              </td>
              <td><small class="text-muted">Recorded</small></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
      <div class="p-3 border-top" style="background:#f8faff;">
        <small class="text-muted">
          <i class="bi bi-info-circle me-1"></i>
          Showing <%= history.length %> records. Your complete attendance history is automatically tracked.
        </small>
      </div>
    <% } else { %>
      <div class="p-5 text-center">
        <div style="font-size:3rem;opacity:0.3;margin-bottom:1rem;"><i class="bi bi-inbox"></i></div>
        <p class="text-muted fw-semibold">No attendance records yet</p>
        <p class="text-muted small mb-3">Start marking your attendance to see your history</p>
        <a href="/attendance/mark" class="btn btn-primary">
          <i class="bi bi-calendar-check me-1"></i> Mark Attendance
        </a>
      </div>
    <% } %>
  </div>

  <!-- Mobile View: Cards -->
  <div class="d-lg-none">
    <% if (history && history.length > 0) { %>
      <div class="d-grid gap-3">
        <% history.forEach(function(record) { %>
          <%
            const isPresent = record.status === 'present';
            const badgeBg = isPresent ? '#d1fae5' : '#fee2e2';
            const badgeTxt = isPresent ? '#065f46' : '#991b1b';
            const bgColor = isPresent ? '#f0fdf4' : '#fef2f2';
          %>
          <div class="card p-4" style="background:<%= bgColor %>;">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <div>
                <h6 class="fw-semibold mb-1" style="color:#1e293b;"><%= record.subjectName %></h6>
                <small class="text-muted">
                  <i class="bi bi-calendar me-1"></i>
                  <%= record.date.toLocaleDateString('en-IN', { weekday:'long', year:'numeric', month:'short', day:'numeric' }) %>
                </small>
              </div>
              <span class="badge rounded-pill fw-semibold" style="background:<%= badgeBg %>;color:<%= badgeTxt %>;">
                <%= isPresent ? '✓ Present' : '✗ Absent' %>
              </span>
            </div>
            <small class="text-muted d-block">Recorded</small>
          </div>
        <% }); %>
      </div>
      <div class="alert rounded-3 mt-3" style="background:#f0f6ff;border:1.5px solid #bfdbfe;color:#1e40af;">
        <small>
          <i class="bi bi-info-circle me-1"></i>
          Showing <%= history.length %> records
        </small>
      </div>
    <% } else { %>
      <div class="card p-5 text-center">
        <div style="font-size:3rem;opacity:0.3;margin-bottom:1rem;"><i class="bi bi-inbox"></i></div>
        <p class="text-muted fw-semibold">No attendance records yet</p>
        <p class="text-muted small mb-3">Start marking your attendance to see your history</p>
        <a href="/attendance/mark" class="btn btn-primary w-100">
          <i class="bi bi-calendar-check me-1"></i> Mark Attendance
        </a>
      </div>
    <% } %>
  </div>

  <div class="mt-4 text-center">
    <a href="/dashboard" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
    </a>
  </div>

</main>

<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function filterBySubject(select) {
    const subject = select.value;
    if (!subject) window.location.href = '/attendance/history';
    else window.location.href = '/attendance/history?subject=' + encodeURIComponent(subject);
  }
</script>
</body>
</html>
