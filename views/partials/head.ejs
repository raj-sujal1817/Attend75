<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= typeof title !== 'undefined' ? title + ' · Attent75' : 'Attent75' %></title>

<!-- Bootstrap 5 CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<!-- Bootstrap Icons -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
<!-- Google Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@600;700&display=swap" rel="stylesheet">

<style>
  :root {
    --blue-deep:   #1a3a5c;
    --blue-mid:    #2563eb;
    --blue-soft:   #dbeafe;
    --blue-accent: #93c5fd;
    --green:       #10b981;
    --red:         #ef4444;
    --amber:       #f59e0b;
    --bg:          #f0f6ff;
    --card-bg:     #ffffff;
    --text:        #1e293b;
    --muted:       #64748b;
  }
  * { font-family: 'Inter', sans-serif; }
  body { background: var(--bg); color: var(--text); min-height: 100vh; display: flex; flex-direction: column; }
  h1,h2,h3,.fw-display { font-family: 'Poppins', sans-serif; }

  .card { border: none; border-radius: 16px; box-shadow: 0 2px 12px rgba(37,99,235,0.08); }
  .card:hover { box-shadow: 0 6px 24px rgba(37,99,235,0.14); transition: box-shadow 0.2s; }

  .stat-card { border-radius: 16px; overflow: hidden; position: relative; }
  .stat-card .stat-icon { width:52px;height:52px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px; }

  .badge-present { background:#d1fae5;color:#065f46;font-weight:600;padding:5px 12px;border-radius:20px; }
  .badge-absent  { background:#fee2e2;color:#991b1b;font-weight:600;padding:5px 12px;border-radius:20px; }

  .btn-primary   { background:var(--blue-mid);border-color:var(--blue-mid);border-radius:10px;font-weight:600;padding:10px 22px; }
  .btn-primary:hover { background:#1d4ed8;border-color:#1d4ed8; }
  .btn-outline-primary { border-color:var(--blue-mid);color:var(--blue-mid);border-radius:10px;font-weight:600; }
  .btn-outline-primary:hover { background:var(--blue-mid);color:#fff; }

  .form-control, .form-select {
    border-radius: 10px;
    border: 1.5px solid #e2e8f0;
    padding: 10px 14px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .form-control:focus, .form-select:focus {
    border-color: var(--blue-mid);
    box-shadow: 0 0 0 3px rgba(37,99,235,0.12);
  }
  .form-label { font-weight: 600; color: var(--text); margin-bottom: 6px; }

  .section-title { font-size: 1.1rem; font-weight: 700; color: var(--blue-deep); letter-spacing: -0.2px; }
  .progress { border-radius: 99px; height: 8px; background: var(--blue-soft); }
  .progress-bar { background: linear-gradient(90deg, var(--blue-mid), #60a5fa); border-radius: 99px; }

  .auth-bg {
    background: linear-gradient(135deg, #1a3a5c 0%, #2563eb 50%, #3b82f6 100%);
    min-height: 100vh;
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
  }
  .auth-bg::before {
    content: '';
    position: absolute; width: 500px; height: 500px;
    border-radius: 50%; background: rgba(255,255,255,0.04);
    top: -100px; right: -150px;
  }
  .auth-bg::after {
    content: '';
    position: absolute; width: 300px; height: 300px;
    border-radius: 50%; background: rgba(255,255,255,0.05);
    bottom: -80px; left: -80px;
  }
  .auth-card { border-radius: 24px; padding: 40px; max-width: 420px; width: 100%; box-shadow: 0 20px 60px rgba(0,0,0,0.2); position: relative; z-index: 2; }

  .table th { background: var(--blue-soft); color: var(--blue-deep); font-weight: 700; border: none; }
  .table td { vertical-align: middle; border-color: #f1f5f9; }
  .table { border-radius: 12px; overflow: hidden; }

  .subject-row:hover { background: #f8faff; }

  .attendance-card { border-radius: 16px; border: 2px solid #e2e8f0; transition: border-color 0.2s; }
  .attendance-card:hover { border-color: var(--blue-mid); }

  .pyq-btn { font-size: 0.8rem; padding: 6px 14px; border-radius: 8px; font-weight: 600; }

  .nav-link { color: rgba(255,255,255,0.85) !important; font-weight: 500; transition: background 0.15s; }
  .nav-link:hover, .nav-link.active { color: #fff !important; }
</style>
