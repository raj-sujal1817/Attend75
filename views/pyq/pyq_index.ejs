<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head', { title: 'PYQ' }) %></head>
<body>

<%- include('../partials/navbar', { page: 'pyq', user: typeof user !== 'undefined' ? user : { username: 'Rahul' } }) %>

<main class="container-fluid px-4 py-4" style="max-width:1200px;">

  <div class="mb-4">
    <h2 class="fw-bold mb-0" style="font-family:'Poppins',sans-serif;color:#1a3a5c;">
      <i class="bi bi-file-earmark-text me-2 text-primary"></i>Previous Year Questions
    </h2>
    <p class="text-muted mb-0 small">Access exam papers from previous years to prepare better</p>
  </div>

  <% if (typeof message !== 'undefined' && message) { %>
    <div class="alert alert-info alert-dismissible fade show rounded-3 mb-4" role="alert">
      <i class="bi bi-info-circle-fill me-2"></i>
      <%= message %>
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  <% } %>

  <%
    const pyqData = typeof subjects !== 'undefined' ? subjects : [
      { name: 'Mathematics', papers: ['2023', '2024', '2025'] },
      { name: 'Physics', papers: ['2023', '2024'] },
      { name: 'Chemistry', papers: ['2023', '2024', '2025'] },
      { name: 'Data Structures', papers: ['2024', '2025'] },
      { name: 'Web Development', papers: ['2025'] },
    ];
  %>

  <!-- Desktop View: Grid -->
  <div class="d-none d-lg-grid gap-4" style="display:grid!important;grid-template-columns:repeat(auto-fill,minmax(380px,1fr));">
    <% pyqData.forEach(function(subj) { %>
      <div class="card p-4 h-100">
        <div class="d-flex align-items-center gap-3 mb-4">
          <div class="d-inline-flex align-items-center justify-content-center rounded-3" style="width:48px;height:48px;background:linear-gradient(135deg,#2563eb,#60a5fa);color:#fff;font-size:20px;">
            <i class="bi bi-journal-text"></i>
          </div>
          <div>
            <h5 class="fw-bold mb-0" style="color:#1a3a5c;"><%= subj.name %></h5>
            <small class="text-muted"><%= subj.papers.length %> papers available</small>
          </div>
        </div>

        <div class="mb-4">
          <p class="fw-semibold text-muted small text-uppercase" style="letter-spacing:.5px;margin-bottom:1rem;">Exam Papers</p>
          <div class="d-grid gap-2">
            <% subj.papers.forEach(function(year) { %>
              <a 
                href="#"
                class="btn btn-outline-primary pyq-btn d-flex align-items-center justify-content-center gap-2"
                onclick="downloadPYQ('<%= subj.name %>', '<%= year %>', event)"
              >
                <i class="bi bi-download"></i> <%= year %> Paper
              </a>
            <% }); %>
          </div>
        </div>

        <hr>
        
        <div class="text-center">
          <small class="text-muted">
            <i class="bi bi-calendar3 me-1"></i>Last updated today
          </small>
        </div>
      </div>
    <% }); %>
  </div>

  <!-- Mobile View: Stacked Cards -->
  <div class="d-lg-none d-grid gap-3">
    <% pyqData.forEach(function(subj) { %>
      <div class="card p-4">
        <div class="d-flex align-items-center gap-3 mb-4">
          <div class="d-inline-flex align-items-center justify-content-center rounded-3" style="width:44px;height:44px;background:linear-gradient(135deg,#2563eb,#60a5fa);color:#fff;font-size:18px;">
            <i class="bi bi-journal-text"></i>
          </div>
          <div>
            <h6 class="fw-bold mb-0" style="color:#1a3a5c;"><%= subj.name %></h6>
            <small class="text-muted"><%= subj.papers.length %> available</small>
          </div>
        </div>

        <div class="d-grid gap-2">
          <% subj.papers.forEach(function(year) { %>
            <a 
              href="#"
              class="btn btn-outline-primary btn-sm d-flex align-items-center justify-content-center gap-2"
              onclick="downloadPYQ('<%= subj.name %>', '<%= year %>', event)"
            >
              <i class="bi bi-download"></i> <%= year %> Paper
            </a>
          <% }); %>
        </div>
      </div>
    <% }); %>
  </div>

  <!-- Info Section -->
  <div class="row mt-4 g-3">
    <div class="col-sm-6 col-md-4">
      <div class="text-center p-3 rounded-3" style="background:#f0f6ff;">
        <div style="font-size:1.8rem;color:#2563eb;margin-bottom:.5rem;"><i class="bi bi-file-pdf"></i></div>
        <p class="fw-semibold small mb-0" style="color:#1a3a5c;"><%= pyqData.length %> Subjects</p>
        <small class="text-muted">Covered</small>
      </div>
    </div>
    <div class="col-sm-6 col-md-4">
      <div class="text-center p-3 rounded-3" style="background:#f0fdf4;">
        <div style="font-size:1.8rem;color:#10b981;margin-bottom:.5rem;"><i class="bi bi-file-earmark-check"></i></div>
        <p class="fw-semibold small mb-0" style="color:#1a3a5c;"><%= pyqData.reduce((acc, s) => acc + s.papers.length, 0) %> Papers</p>
        <small class="text-muted">Available</small>
      </div>
    </div>
    <div class="col-sm-6 col-md-4">
      <div class="text-center p-3 rounded-3" style="background:#fef3c7;">
        <div style="font-size:1.8rem;color:#f59e0b;margin-bottom:.5rem;"><i class="bi bi-calendar-event"></i></div>
        <p class="fw-semibold small mb-0" style="color:#1a3a5c;">2023-2025</p>
        <small class="text-muted">Year Range</small>
      </div>
    </div>
  </div>

  <!-- Tip Section -->
  <div class="alert rounded-3 mt-4 d-flex gap-3 align-items-start" style="background:#fef3c7;border:1.5px solid #fcd34d;color:#92400e;">
    <i class="bi bi-lightbulb me-1 flex-shrink-0 mt-1" style="font-size:1.1rem;"></i>
    <div style="font-size:.9rem;">
      <strong>Pro Tip:</strong> Download and solve previous year papers regularly. This is one of the best ways to prepare for exams and understand the exam pattern.
    </div>
  </div>

  <div class="mt-4 text-center">
    <a href="/dashboard" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
    </a>
  </div>

</main>

<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function downloadPYQ(subject, year, e) {
    e.preventDefault();
    // In a real app, this would trigger a file download from the server
    // For now, we'll show a toast notification
    const msg = document.createElement('div');
    msg.className = 'position-fixed bottom-0 start-50 translate-middle-x mb-3 alert alert-success rounded-3 shadow';
    msg.style.zIndex = '9999';
    msg.innerHTML = `
      <i class="bi bi-check-circle me-2"></i>
      Starting download: <strong>${subject} ${year} Paper</strong>
    `;
    document.body.appendChild(msg);
    setTimeout(() => msg.remove(), 3000);
    
    // In production, replace with:
    // window.location.href = \`/pyq/download?subject=\${encodeURIComponent(subject)}&year=\${year}\`;
  }
</script>
</body>
</html>
