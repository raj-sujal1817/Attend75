<!DOCTYPE html>
<html lang="en">
<head><%- include("../partials/head.ejs", { title: 'Semester Setup' }) %></head>

<body>

<%- include('../partials/navbar', { page: 'semester', user: typeof user !== 'undefined' ? user : { username: 'Rahul' } }) %>

<main class="container py-5" style="max-width:600px;">

  <div class="mb-4">
    <a href="/dashboard" class="text-decoration-none text-muted small d-flex align-items-center gap-1 mb-3">
      <i class="bi bi-arrow-left"></i> Back to Dashboard
    </a>
    <h2 class="fw-bold mb-1" style="font-family:'Poppins',sans-serif;color:#1a3a5c;">Semester Setup</h2>
    <p class="text-muted mb-0">Define your semester dates to track progress and attendance accurately.</p>
  </div>

  <!-- Info Banner -->
  <div class="alert d-flex align-items-start gap-3 border-0 rounded-3 mb-4" style="background:#eff6ff;color:#1e40af;">
    <i class="bi bi-info-circle-fill mt-1 flex-shrink-0" style="font-size:1.1rem;"></i>
    <div>
      <strong>Why set up your semester?</strong><br>
      <span class="small">Attent75 uses these dates to calculate days remaining, track your overall progress, and give accurate attendance predictions.</span>
    </div>
  </div>

  <div class="card p-4 p-md-5">

    <% if (typeof success !== 'undefined' && success) { %>
      <div class="alert alert-success d-flex align-items-center gap-2 rounded-3 mb-4">
        <i class="bi bi-check-circle-fill text-success"></i>
        Semester dates saved successfully!
      </div>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger d-flex align-items-center gap-2 rounded-3 mb-4">
        <i class="bi bi-exclamation-circle-fill text-danger"></i>
        <%= error %>
      </div>
    <% } %>

    <form action="/semester/setup" method="POST">

      <div class="mb-4">
        <label class="form-label" for="semName">
          <i class="bi bi-calendar-plus me-1 text-primary"></i> Semester Name
        </label>
        <input
          type="text"
          name="semesterName"
          id="semName"
          value="<%= semester && semester.semesterName ? semester.semesterName : '' %>"
          required
          placeholder="Semester name"
          class="form-control form-control-lg"
          required
        >
        <div class="form-text">In which semester of b.tech</div>
      </div>

      <div class="mb-4">
        <label class="form-label" for="startDate">
          <i class="bi bi-calendar-plus me-1 text-primary"></i> Semester Start Date
        </label>
        <input
          type="date"
          name="startDate"
          id="startDate"
          class="form-control form-control-lg"
          value="<%= semester && semester.startDate ? semester.startDate.toISOString().split('T')[0] : '' %>"
          required
        >
        <div class="form-text">The first day of your current semester</div>
      </div>

      <div class="mb-4">
        <label class="form-label" for="endDate">
          <i class="bi bi-calendar-x me-1 text-primary"></i> Semester End Date
        </label>
        <input
          type="date"
          name="endDate"
          id="endDate"
          class="form-control form-control-lg"
          value="<%= semester && semester.endDate ? semester.endDate.toISOString().split('T')[0] : '' %>"
          required

        >
        <div class="form-text">The last day of your exams or semester</div>
      </div>

      <!-- Preview Card (populated by JS) -->
      <div id="previewCard" class="rounded-3 p-3 mb-4 d-none" style="background:#f0f6ff;border:1.5px solid #bfdbfe;">
        <p class="fw-semibold text-primary mb-2 small"><i class="bi bi-calendar-range me-1"></i>Semester Preview</p>
        <div class="d-flex justify-content-around text-center">
          <div>
            <div class="fw-bold" style="color:#1a3a5c;" id="prevDuration">—</div>
            <div class="text-muted" style="font-size:.75rem;">Total Days</div>
          </div>
          <div>
            <div class="fw-bold" style="color:#1a3a5c;" id="prevRemaining">—</div>
            <div class="text-muted" style="font-size:.75rem;">Days Left</div>
          </div>
          <div>
            <div class="fw-bold" style="color:#1a3a5c;" id="prevProgress">—%</div>
            <div class="text-muted" style="font-size:.75rem;">Progress</div>
          </div>
        </div>
      </div>

      <button type="submit" class="btn btn-primary btn-lg w-100">
        <i class="bi bi-floppy me-2"></i>Save Semester
      </button>
    </form>
  </div>
</main>

<%- include('../partials/footer') %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  const startEl = document.getElementById('startDate');
  const endEl   = document.getElementById('endDate');
  const card    = document.getElementById('previewCard');

  function updatePreview() {
    if (!startEl.value || !endEl.value) { card.classList.add('d-none'); return; }
    const s = new Date(startEl.value), e = new Date(endEl.value), now = new Date();
    if (e <= s) { card.classList.add('d-none'); return; }
    const total = Math.round((e - s) / 86400000);
    const left  = Math.max(0, Math.round((e - now) / 86400000));
    const pct   = Math.min(100, Math.round(((now - s) / (e - s)) * 100));
    document.getElementById('prevDuration').textContent  = total;
    document.getElementById('prevRemaining').textContent = left;
    document.getElementById('prevProgress').textContent  = pct + '%';
    card.classList.remove('d-none');
  }
  startEl.addEventListener('change', updatePreview);
  endEl.addEventListener('change', updatePreview);
  updatePreview();
</script>
</body>
</html>
