<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head', { title: 'Login' }) %></head>
<body class="p-0 m-0" style="background:none;">

<div class="auth-bg">
  <div class="w-100 px-3 d-flex flex-column align-items-center">

    <!-- Brand -->
    <div class="text-center mb-4 position-relative" style="z-index:2;">
      <div class="d-inline-flex align-items-center justify-content-center rounded-3 mb-3" style="width:64px;height:64px;background:rgba(255,255,255,0.15);">
        <i class="bi bi-calendar2-check text-white" style="font-size:28px;"></i>
      </div>
      <h1 class="text-white fw-bold mb-1" style="font-family:'Poppins',sans-serif;font-size:2rem;">Attent<span style="color:#93c5fd;">75</span></h1>
      <p class="text-white-50 mb-0 small">Your attendance, always on track.</p>
    </div>

    <!-- Card -->
    <div class="auth-card bg-white">
      <h2 class="fw-bold mb-1" style="font-family:'Poppins',sans-serif;font-size:1.5rem;color:#1a3a5c;">Welcome back</h2>
      <p class="text-muted mb-4 small">Sign in to continue to your dashboard</p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger d-flex align-items-center gap-2 rounded-3 py-2 mb-4">
          <i class="bi bi-exclamation-circle-fill text-danger"></i>
          <span><%= error %></span>
        </div>
      <% } %>

      <form action="/login" method="POST" novalidate>
        <div class="mb-3">
          <label class="form-label" for="email">
            <i class="bi bi-envelope me-1 text-primary"></i> Email Address
          </label>
          <input
            type="email"
            name="email"
            id="email"
            class="form-control form-control-lg"
            placeholder="you@college.edu"
            value="<%= typeof formData !== 'undefined' ? formData.email : '' %>"
            required
          >
        </div>

        <div class="mb-4">
          <label class="form-label" for="password">
            <i class="bi bi-lock me-1 text-primary"></i> Password
          </label>
          <div class="input-group">
            <input
              type="password"
              name="password"
              id="password"
              class="form-control form-control-lg"
              placeholder="Enter your password"
              required
            >
            <button class="btn btn-outline-secondary border rounded-end-3" type="button" onclick="togglePwd('password', this)" tabindex="-1" style="border-left:0!important;border-color:#e2e8f0!important;">
              <i class="bi bi-eye"></i>
            </button>
          </div>
        </div>

        <button type="submit" class="btn btn-primary w-100 btn-lg mb-3">
          <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
        </button>
      </form>

      <p class="text-center text-muted mb-0 small">
        Don't have an account?
        <a href="/signup" class="text-primary fw-semibold text-decoration-none">Create account</a>
      </p>
    </div>

    <p class="text-white-50 small mt-4 position-relative" style="z-index:2;">&copy; <%= new Date().getFullYear() %> Attent75</p>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function togglePwd(id, btn) {
    const el = document.getElementById(id);
    const icon = btn.querySelector('i');
    if (el.type === 'password') { el.type = 'text'; icon.className = 'bi bi-eye-slash'; }
    else { el.type = 'password'; icon.className = 'bi bi-eye'; }
  }
</script>
</body>
</html>
